{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Expo Dev Server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--port", "8081"],
      "port": 8081
    },
    {
      "name": "Expo (iOS Simulator)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--ios"],
      "port": 8081
    },
    {
      "name": "Expo (Android Emulator)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--android"],
      "port": 8081
    },
    {
      "name": "Watch App (Simulator)",
      "runtimeExecutable": "xcodebuild",
      "runtimeArgs": ["-workspace", "ios/FitnessApp.xcworkspace", "-scheme", "TRAKWatch Watch App", "-configuration", "Debug", "-derivedDataPath", "ios/build", "-arch", "arm64", "-sdk", "watchsimulator", "install"],
      "port": null
    }
  ]
}
