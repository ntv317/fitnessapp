default_platform(:ios)

WORKSPACE   = "FitnessApp.xcworkspace"
SCHEME      = "FitnessApp"
APP_ID      = "io.liftr.app"
WATCH_ID    = "io.liftr.app.watchkitapp"

platform :ios do
  desc "Build and upload a new build to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id:      ENV["ASC_KEY_ID"],
      issuer_id:   ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_P8"], # base64-decoded .p8 contents
      is_key_content_base64: true,
      in_house: false
    )

    # Pull distribution cert + App Store profiles from the match repo.
    # readonly in CI so a build never mints new certs; create them locally first.
    match(
      type: "appstore",
      app_identifier: [APP_ID, WATCH_ID],
      api_key: api_key,
      readonly: is_ci
    )

    # Next build number = one above the latest already on TestFlight.
    next_build = latest_testflight_build_number(
      app_identifier: APP_ID,
      api_key: api_key
    ) + 1
    increment_build_number(xcodeproj: "FitnessApp.xcodeproj", build_number: next_build)

    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          APP_ID   => "match AppStore #{APP_ID}",
          WATCH_ID => "match AppStore #{WATCH_ID}"
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
